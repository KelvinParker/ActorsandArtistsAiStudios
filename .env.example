# --- ACTORS AND ARTISTS AI STUDIOS ---
# Copy this file to .env.local and fill in real values (never commit .env.local).

# SUPABASE (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your_project_url
# New publishable key (sb_publishable_…) — preferred if legacy anon JWT fails
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_default_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only — bypasses RLS; never use NEXT_PUBLIC_ or commit this.
# Required for /admin/cast, /admin/add-actor, and POST /api/actors/[id]/taxonomy.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional — scan a Supabase Storage folder on a schedule or via POST /api/admin/sync-actors-from-storage
# Same layout as admin zip/folder import: numbered .txt and/or one .rtf per actor (section titles → columns; see docs/gemini-actor-folder-fields.md Option C), plus images.
# If you use …/Profiles/Camille/headshots + Camille.rtf, set PREFIX through Profiles (e.g. actor-assets/Profiles) so paths resolve as Camille/… not Profiles/Camille/… (else "Profiles" becomes pack_name). Set DEFAULT_PACK or Profiles/DEFAULT_PACK.txt for the real pack.
# ACTOR_IMPORT_SYNC_BUCKET=your_import_bucket_name
# ACTOR_IMPORT_SYNC_PREFIX=actor-assets/Profiles
# ACTOR_IMPORT_SYNC_DEFAULT_PACK=Dirty South
# ACTOR_IMPORT_SYNC_CRON_SECRET=long_random_string

# Supabase CLI only (npm run db:link / db:push) — not read by Next.js.
# Personal access token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token
# Project ref: Dashboard → Project Settings → General → Reference ID
SUPABASE_PROJECT_REF=your_project_ref

# CLERK (Dashboard > API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key
# Admin access to /admin (any one is enough):
# - Clerk user IDs:
# ADMIN_CLERK_USER_IDS=user_xxxxxxxxxxxxxxxxxxxxxxxx
# - Primary email allowlist (case-insensitive):
# ADMIN_EMAILS=you@example.com
# - Or set Clerk user publicMetadata.role or privateMetadata.role to "admin" in Dashboard

# FAL.AI (fal.ai > Keys) — image fallbacks in lib/character-automation.ts and DNA LoRA training on actor profiles (admin).
FAL_KEY=your_fal_key
# Optional: when set with a public app URL, Fal queue jobs include a webhook to POST /api/webhooks/fal?token=…
# Use a long random string. Same value must not be exposed to the browser.
# FAL_WEBHOOK_SECRET=long_random_secret
# Public site URL for webhooks (local: http://localhost:3000). Vercel sets VERCEL_URL automatically if unset.
# NEXT_PUBLIC_APP_URL=https://your-deployment.example.com

# LEVEL LABS (levellabs.ai / dashboard API keys)
LEVELLABS_API_KEY=your_levellabs_key

# ELEVENLABS (optional — for future server-side TTS / voice API; not required for admin Voice review UI)
# https://elevenlabs.io/docs / Dashboard → API keys
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Ops: only use ElevenLabs UI previews/listening that are free for your plan; see lib/elevenlabs-links.ts (elevenlabsPreviewUsageNote).

# Partner integration: same keys for catalog + per-character pack (comma-separated; Bearer or x-api-key)
# GET /api/v1/characters — paginated roster; GET /api/v1/characters/[id] — full pack (LoRA, images, voice, etc.)
# GET /api/v1/openapi — public OpenAPI 3 JSON (no auth) for Postman / codegen
# Outbound webhooks (optional): Clerk admins register partner HTTPS URLs in table partner_pack_webhooks via POST /api/admin/partner-pack-webhooks (same key as CHARACTER_PACK_API_KEYS).
# CHARACTER_PACK_API_KEYS=long_random_key_one,long_random_key_two

# VERCEL (npx vercel link, or copy projectId/orgId from .vercel/project.json)
VERCEL_PROJECT_ID=your_project_id
VERCEL_ORG_ID=your_org_id

# GOOGLE AI (For Gemini inside Cursor - optional if already in Settings)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_key
# Preferred direct image model (avoid preview IDs)
IMAGE_MODEL=gemini-3.1-flash-image
# Optional: Google Flow webhook for Nano Banana turnaround generation
GOOGLE_FLOW_WEBHOOK_URL=your_google_flow_webhook_url
# Optional bearer token if your Flow webhook requires auth
GOOGLE_FLOW_API_KEY=your_google_flow_api_key

# GITHUB (github.com/settings/personal-access-tokens)
# Use only if your *code* calls the GitHub API (server-side). For `git push`, use Terminal
# or GitHub Desktop — those do NOT read this file.
GITHUB_TOKEN=your_github_personal_access_token
# Optional — only if you add GitHub OAuth later (GitHub Developer Settings > OAuth Apps)
# GITHUB_CLIENT_ID=your_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_oauth_app_client_secret
