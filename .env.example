# --- ACTORS AND ARTISTS AI STUDIOS ---
# Copy this file to .env.local and fill in real values (never commit .env.local).

# SUPABASE (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# CLERK (Dashboard > API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key

# FAL.AI (fal.ai > Keys)
FAL_KEY=your_fal_key

# LEVEL LABS (levellabs.ai / dashboard API keys)
LEVELLABS_API_KEY=your_levellabs_key

# VERCEL (npx vercel link, or copy projectId/orgId from .vercel/project.json)
VERCEL_PROJECT_ID=your_project_id
VERCEL_ORG_ID=your_org_id

# GOOGLE AI (For Gemini inside Cursor - optional if already in Settings)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_key

# GITHUB (github.com/settings/personal-access-tokens)
# Use only if your *code* calls the GitHub API (server-side). For `git push`, use Terminal
# or GitHub Desktop — those do NOT read this file.
GITHUB_TOKEN=your_github_personal_access_token
# Optional — only if you add GitHub OAuth later (GitHub Developer Settings > OAuth Apps)
# GITHUB_CLIENT_ID=your_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_oauth_app_client_secret
